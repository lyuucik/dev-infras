{
	// --- Темы и Оформление (Nord-friendly) ---
	"workbench.colorTheme": "Tokyo Night Storm",
	"workbench.activityBar.location": "hidden",
	"workbench.editor.showTabs": "single",
	"workbench.editor.showIcons": false,
	"workbench.statusBar.visible": true,
	"window.commandCenter": false,
	"breadcrumbs.enabled": false,
	"editor.minimap.enabled": false,
	"editor.glyphMargin": false,
	"editor.folding": true,
	// Убираем рамки для монолитности (под Nord)
	"workbench.colorCustomizations": {
		"sideBar.border": "#00000000",
		"editorGroup.border": "#00000000",
		"statusBar.border": "#00000000",
		"editorLineNumber.foreground": "#4c566a77",
		"editorLineNumber.activeForeground": "#88c0d0"
	},
	// --- Текст и Плавность ---
	"editor.fontSize": 14,
	"editor.lineHeight": 1.6, // Чуть больше воздуха
	"editor.fontLigatures": true,
	"editor.cursorBlinking": "smooth", // "phase" хорош, но "smooth" мягче
	"editor.cursorSmoothCaretAnimation": "on",
	"editor.smoothScrolling": true,
	"editor.scrollBeyondLastLine": false,
	"editor.renderWhitespace": "none", // Для истинного минимализма
	"editor.wordWrap": "on", // Вместо линеек (rulers)
	// --- Vim Logic (Исправлено) ---
	"vim.useSystemClipboard": true,
	"vim.useCtrlKeys": true,
	"vim.hlsearch": true,
	"vim.leader": "<space>",
	"vim.easymotion": true,
	"vim.handleKeys": {
		"<C-f>": false,
		"<C-p>": false,
		"<C-s>": false,
		"<C-z>": false,
		"<C-r>": false
	},
	"vim.normalModeKeyBindingsNonRecursive": [
		{
			"before": [
				"<leader>",
				"f",
				"f"
			],
			"commands": [
				"workbench.action.quickOpen"
			]
		},
		{
			"before": [
				"<leader>",
				"f",
				"w"
			],
			"commands": [
				"workbench.action.findInFiles"
			]
		},
		{
			"before": [
				"<leader>",
				"b",
				"b"
			],
			"commands": [
				"workbench.action.showAllEditorsByMostRecent"
			]
		},
		{
			"before": [
				"<leader>",
				"/"
			],
			"commands": [
				"editor.action.commentLine"
			]
		},
		{
			"before": [
				"<leader>",
				"n"
			],
			"commands": [
				"workbench.action.toggleSidebarVisibility"
			]
		},
		{
			"before": ["<leader>", "d", "b"],
			"commands": ["editor.debug.action.toggleBreakpoint"]
		},
		{
			"before": ["<leader>", "d", "c"],
			"commands": ["editor.debug.action.conditionalBreakpoint"]
		},
				{
			"before": [
				"g",
				"d"
			],
			"commands": [
				"editor.action.revealDefinition"
			]
		}, // Go to Definition (Перейти к определению)
		{
			"before": [
				"g",
				"i"
			],
			"commands": [
				"editor.action.goToImplementation"
			]
		}, // Go to Implementation (К реализации)
		{
			"before": [
				"g",
				"r"
			],
			"commands": [
				"editor.action.goToReferences"
			]
		}, // Показать все ссылки на символ в плавающем окне
		{
			"before": [
				"<leader>",
				"k"
			],
			"commands": [
				"editor.action.showHover"
			]
		}, // Показать документацию/тип при наведении (вместо мышки)
				{
			"before": [
				"<leader>",
				"s"
			],
			"commands": [
				"workbench.action.gotoSymbol"
			]
		}, // Поиск по символам ВНУТРИ файла (функции, переменные)
		{
			"before": [
				"<leader>",
				"S"
			],
			"commands": [
				"workbench.action.showAllSymbols"
			]
		}, // Поиск по символам во ВСЕМ проекте
	],
	// --- Системное ---
	"editor.formatOnSave": true,
	"terminal.integrated.fontSize": 13,
	"terminal.integrated.fontFamily": "'JetBrains Mono', monospace",
	"terminal.integrated.cursorStyle": "line",
	"terminal.integrated.defaultProfile.windows": "PowerShell"
}
